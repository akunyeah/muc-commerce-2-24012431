# =====================================================================
# 大模型 API 配置 —— 任选一种方式填写即可，填好后重启 Flask
# =====================================================================

# --- 方式一 · OpenAI 兼容 API（推荐，可对接 DeepSeek / Ollama / LM Studio / 豆包 等）---
# 示例：使用 DeepSeek（国内可直接访问，注册免费额度）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 也可以换成其它兼容服务：
# - 本地 Ollama:    OPENAI_BASE_URL=http://localhost:11434/v1   OPENAI_MODEL=qwen2.5:7b
# - LM Studio:      OPENAI_BASE_URL=http://localhost:1234/v1   OPENAI_MODEL=（加载的模型名）
# - 火山方舟:       OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3  OPENAI_MODEL=doubao-pro-32k
# - OpenAI 官方:    OPENAI_BASE_URL=https://api.openai.com/v1   OPENAI_MODEL=gpt-4o-mini

# --- 方式二 · 阿里云 DashScope（通义千问）---
# DASHSCOPE_API_KEY=sk-你的dashscope密钥
# DASHSCOPE_MODEL=qwen-plus