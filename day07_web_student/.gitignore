.env                 # 大模型 API Key
*.env                # 任何 .env 后缀的文件
.api_key             # 其他密钥文件
# ============================================
# Python / Flask 运行产生的临时文件
# ============================================
__pycache__/
*.pyc
*.pyo
*.log